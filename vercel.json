{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist/public",
  "framework": null,
  "regions": ["lhr1"],
  "redirects": [
    {
      "source": "/statutory-redundancy-pay",
      "destination": "/statutory-redundancy-pay-calculator",
      "permanent": true
    },
    {
      "source": "/voluntary-redundancy",
      "destination": "/voluntary-redundancy-calculator",
      "permanent": true
    },
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "permanent": true
    }
  ],
  "functions": {
    "api/[[...path]].ts": {
      "maxDuration": 60,
      "includeFiles": "dist/vercel-handler.cjs"
    },
    "api/html.ts": {
      "includeFiles": "dist/seo-handler.cjs"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/api/html?pathname=$1"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  }
}
