# =============================================================================
# RedundancyCalculatorUK — environment variables
# Domain: https://redundancycalculatoruk.co.uk
#
# Copy to .env and fill in your values. NEVER put real secrets in this file.
# (.env is gitignored; .env.example is committed as a template only.)
# =============================================================================

# --- Brief AI mode ---
# off = templates + engine only (no API)
# lite = optional AI for executive headline + 3 observations only (recommended)
# legacy = full AI narrative (rollback only)
BRIEF_AI_MODE=lite

# --- Local development ---
# Unlock /results and brief generation without Stripe (never set in production)
DEV_GRANT_REPORT_ACCESS=1

# --- Core ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
PORT=5000
NODE_ENV=development

# Long random string for express-session (required in production)
SESSION_SECRET=change-me-in-production

# --- Email (Resend) — optional; access links still work without it ---
RESEND_API_KEY=
ACCESS_EMAIL_FROM=noreply@redundancycalculatoruk.co.uk

# --- Admin portal (/admin/resets) ---
ADMIN_PASSWORD=change-me-local-admin

# --- Granted access (production owner / team emails — comma-separated) ---
# Grants full Intelligence Report + Reset portal without Stripe. Never commit real emails here.
# GRANTED_ACCESS_EMAILS=you@example.com

# --- OpenAI — required for Private Runway Brief generation ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# --- Stripe — required for £79 report and £95 reset checkout ---
# Dashboard: https://dashboard.stripe.com/apikeys
#
# Use TEST keys for local dev (sk_test_... / pk_test_...).
# Use LIVE keys only in production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
#
# Create products + price IDs (run once after adding secret key):
#   npm run stripe:setup
STRIPE_PRICE_REPORT=price_...
STRIPE_PRICE_RESET=price_...
#
# Webhook signing secret
# Production: https://redundancycalculatoruk.co.uk/api/stripe-webhook
#   Events: checkout.session.completed, checkout.session.async_payment_succeeded
# Local: stripe listen --forward-to localhost:5000/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Replit only (optional fallback if STRIPE_SECRET_KEY is not set) ---
# REPLIT_CONNECTORS_HOSTNAME=
# REPL_IDENTITY=
#
# --- Resend testing (optional) ---
# RESEND_TEST_TO=you@example.com
#
# --- Vercel (set automatically on preview deployments) ---
# VERCEL=1
# VERCEL_URL=your-preview-url.vercel.app
